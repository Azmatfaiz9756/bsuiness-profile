{
  "entities": {
    "Profile": {
      "title": "Business Profile",
      "description": "Public business profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Booking request from client",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "profileId": { "type": "string" }
      },
      "required": ["customerName", "customerEmail", "date", "time", "profileId"]
    },
    "Inquiry": {
      "title": "Lead/Inquiry",
      "description": "Contact message from client",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "profileId": { "type": "string" }
      },
      "required": ["name", "email", "message", "profileId"]
    },
    "Follower": {
      "title": "Follower",
      "description": "User who follows a business profile",
      "type": "object",
      "properties": {
        "profileId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["profileId", "email"]
    },
    "Campaign": {
      "title": "Marketing Campaign",
      "description": "Broadcast message sent to followers",
      "type": "object",
      "properties": {
        "profileId": { "type": "string" },
        "message": { "type": "string" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["WhatsApp", "Push", "Email"] },
        "status": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" }
      },
      "required": ["profileId", "message", "type"]
    }
  },
  "firestore": {
    "/profiles/{uid}": {
      "schema": "Profile",
      "description": "Professional profiles"
    },
    "/appointments/{id}": {
      "schema": "Appointment",
      "description": "Client bookings"
    },
    "/leads/{id}": {
      "schema": "Inquiry",
      "description": "Contact inquiries"
    },
    "/followers/{id}": {
      "schema": "Follower",
      "description": "Business followers"
    },
    "/campaigns/{id}": {
      "schema": "Campaign",
      "description": "Marketing broadcasts"
    }
  }
}
