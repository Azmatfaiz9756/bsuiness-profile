{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Core account data for the professional user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "plan": { "type": "string", "enum": ["Free", "Basic", "Enterprise"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "verified": { "type": "boolean" }
      },
      "required": ["email", "name"]
    },
    "Profile": {
      "title": "Digital Card Profile",
      "description": "Public-facing digital business card details",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "whatsapp": { "type": "string" },
        "quickPayAmount": { "type": "number" },
        "quickPayCurrency": { "type": "string", "enum": ["AED", "USD", "INR"] },
        "templateId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "Appointment": {
      "title": "Booking",
      "description": "Client appointment booking",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "service": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Completed", "Cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "clientName", "clientEmail"]
    },
    "Card": {
      "title": "NFC Card Stock",
      "description": "Pre-printed cards with dynamic redirect serials",
      "type": "object",
      "properties": {
        "serial": { "type": "string" },
        "dynamicUrl": { "type": "string" },
        "profileId": { "type": "string" },
        "status": { "type": "string", "enum": ["Stock", "Active", "Blocked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["serial", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User account documents"
    },
    "/profiles/{profileId}": {
      "schema": "Profile",
      "description": "Digital business card documents"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Booking records"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "Inventory management for NFC cards"
    }
  }
}
