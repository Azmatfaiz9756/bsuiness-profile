rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. GLOBAL SAFETY NET: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: GLOBAL HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Platform admin email protection
      return isSignedIn() && request.auth.token.email == 'azmatfaiz9756@gmail.com' && isEmailVerified();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- PHASE 4: ENTITY VALIDATORS ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 100 &&
             data.name is string && data.name.size() <= 100 &&
             (!data.keys().contains('plan') || data.plan in ['Free', 'Basic', 'Enterprise']);
    }

    function isValidProfile(data) {
      return isValidId(data.ownerId) &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             (!data.keys().contains('quickPayAmount') || data.quickPayAmount is number) &&
             (!data.keys().contains('quickPayCurrency') || data.quickPayCurrency in ['AED', 'USD', 'INR']);
    }

    function isValidAppointment(data) {
      return isValidId(data.ownerId) &&
             data.clientName is string && data.clientName.size() <= 100 &&
             data.clientEmail is string && data.clientEmail.size() <= 100 &&
             data.status in ['Pending', 'Confirmed', 'Completed', 'Cancelled'];
    }

    // --- PHASE 5: COLLECTION MATCHES ---

    // Users: Private data, only owner can access
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL']);
    }

    // Profiles: Publicly readable, owner manages
    match /profiles/{docId} {
      allow read: if true;
      allow create: if isOwner(docId) && isValidProfile(incoming());
      allow update: if (isOwner(docId) || isAdmin()) && 
                    isValidProfile(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'name', 'bio', 'photoURL', 'whatsapp', 'quickPayAmount', 
                      'quickPayCurrency', 'templateId', 'updatedAt', 'services', 
                      'socials', 'testimonials', 'faqs', 'gallery', 'videos'
                    ]);
      allow delete: if isOwner(docId) || isAdmin();
    }

    // Appointments & Leads
    match /appointments/{appId} {
      allow create: if isValidAppointment(incoming()); // Visitors can create
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if isOwner(existing().ownerId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isOwner(existing().ownerId) || isAdmin();
    }

    match /leads/{leadId} {
      allow create: if true; // Any visitor
      allow read, write: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Chat Sessions
    match /chat_sessions/{sessionId} {
      allow create: if true;
      allow get: if true;
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read, create: if true;
        allow update, delete: if false; // Messages are immutable for security
      }
    }

    // Generic protections for remaining paths
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
