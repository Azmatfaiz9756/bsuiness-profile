# GEMINI_API_KEY: Required for Gemini AI API calls on the server.
GEMINI_API_KEY="AIzaSy..."

# VITE_GEMINI_API_KEY: Optional. Exposes the key to the frontend if direct client-side calls are needed.
VITE_GEMINI_API_KEY="AIzaSy..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# STRIPE_SECRET_KEY: Required for generating Stripe checkout sessions
STRIPE_SECRET_KEY="sk_test_..."
