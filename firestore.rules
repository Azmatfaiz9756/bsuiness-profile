rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Allow specific email as an admin to read all data in the dashboard
      return isSignedIn() && request.auth.token.email == 'azmatfaiz9756@gmail.com';
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Profiles: Anyone can read, owner can write
    match /profiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // Appointments & Leads: Visitors can create, owner can manage
    match /appointments/{appId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // Followers & Campaigns
    match /followers/{folId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }
    match /campaigns/{cmpId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Chat Sessions: Secure capability-based access for guests
    match /chat_sessions/{sessionId} {
      allow create: if true;
      allow get: if true; // Guest needs this if they have the ID
      // Only list if the profile belongs to the signed-in user OR it's the platform and user is a super admin
      allow list: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      
      allow update: if true;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      
      match /messages/{messageId} {
        allow create: if true;
        allow read: if true; // Inherits obscurity of sessionId
        allow update, delete: if isSignedIn();
      }
    }

    // Other collections
    match /products/{prodId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /settings/{doc} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /test/{doc} {
      allow read, write: if true;
    }
  }
}
